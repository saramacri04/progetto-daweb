<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0 rounded-4 mt-5">
            <div class="card-body p-5">
                <h2 class="fw-bold text-center mb-4">Bentornato!</h2>
                <p class="text-muted text-center mb-4">Accedi per gestire i tuoi annunci e i tuoi acquisti.</p>
                
                {{#if error}}
                <div class="alert alert-danger mb-4" role="alert">
                    {{error}}
                </div>
                {{/if}}

                {{#if registered}}
                <div class="alert alert-success mb-4" role="alert">
                    Registrazione completata! Puoi ora effettuare l'accesso.
                </div>
                {{/if}}
                
                <form action="/login" method="POST">
                    <div class="mb-3">
                        <label for="email" class="form-label fw-medium">Indirizzo Email</label>
                        <input type="email" class="form-control form-control-lg" id="email" name="email" placeholder="nome@esempio.com" required>
                    </div>
                    <div class="mb-4">
                        <label for="password" class="form-label fw-medium">Password</label>
                        <input type="password" class="form-control form-control-lg" id="password" name="password" placeholder="••••••••" required>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg fw-semibold">Accedi</button>
                    </div>
                </form>

                <div class="text-center mt-4">
                    <p class="text-muted mb-0">Non hai un account? <a href="/register" class="text-decoration-none fw-semibold">Registrati ora</a></p>
                </div>
            </div>
        </div>
    </div>
</div>
