<div class="row align-items-center mb-5">
    <div class="col-lg-6">
        <h1 class="display-4 fw-bold text-dark mb-4">{{title}}</h1>
        <p class="lead text-muted mb-4">{{description}}</p>
        <div class="d-flex gap-3">
            <a href="/login" class="btn btn-outline-dark btn-lg px-4">Log in</a>
            <a href="/register" class="btn btn-primary btn-lg px-4">Start selling</a>
        </div>
    </div>
    <div class="col-lg-6 text-center mt-5 mt-lg-0">
        <!-- Temporary placeholder for hero animation/image -->
        <div class="p-5 bg-white rounded-4 shadow-sm border">
            <h3 class="fw-bold">Give your items a second life! 🌍</h3>
            <p class="text-muted mt-3">Join thousands of users exchanging value every day.</p>
        </div>
    </div>
</div>

<div class="row text-center mt-5">
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
                <h4 class="card-title fw-bold">1. Register</h4>
                <p class="card-text text-muted">Create your account in seconds and join the community.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
                <h4 class="card-title fw-bold">2. Publish</h4>
                <p class="card-text text-muted">Take a photo, add a description and choose the price.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body p-4">
                <h4 class="card-title fw-bold">3. Sell</h4>
                <p class="card-text text-muted">Seal the deal, make money and free up space at home.</p>
            </div>
        </div>
    </div>
</div>
