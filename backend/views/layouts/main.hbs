<!DOCTYPE html>
<html lang="it">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <!-- Includi Bootstrap da CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
        }
    </style>
</head>

<body class="d-flex flex-column min-vh-100">
    <!-- Navbar base condivisa per le pagine HBS -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
        <div class="container py-2">
            <a class="navbar-brand fw-bold text-primary fs-4" href="/">🌿 EcoMarket</a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="/">Home</a>
                    </li>
                    <li class="nav-item px-2 border-start ms-2 d-none d-lg-block"></li>
                    {{#if user}}
                    <li class="nav-item dropdown">
                        <a class="nav-link fw-semibold dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle me-1"></i> Ciao, {{user.name}}!
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                            <li><a class="dropdown-item" href="/dashboard">Il mio Profilo</a></li>
                            {{#if (eq user.role 'admin')}}
                            <li><a class="dropdown-item" href="/admin">Dashboard Admin</a></li>
                            {{/if}}
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger fw-medium" href="/logout">Esci</a></li>
                        </ul>
                    </li>
                    {{else}}
                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="/login">Accedi</a>
                    </li>
                    <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                        <a class="btn btn-primary px-4 fw-semibold rounded-pill shadow-sm"
                            href="/register">Registrati</a>
                    </li>
                    {{/if}}
                </ul>
            </div>
        </div>
    </nav>

    <!-- Contenitore principale dove vengono iniettate le views -->
    <main class="container my-5 min-vh-100">
        {{{body}}}
    </main>

    <!-- Footer base -->
    <footer class="bg-white border-top py-4 mt-auto">
        <div class="container text-center text-muted">
            <p class="mb-1 fw-medium">&copy; 2026 EcoMarket. Tutti i diritti riservati.</p>
            <small>Progetto Universitario - Sviluppo Applicazioni Web</small>
        </div>
    </footer>

    <!-- Script Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>