<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0 rounded-4 mt-4 mb-5">
            <div class="card-body p-5">
                <h2 class="fw-bold text-center mb-4">Crea un Account</h2>
                <p class="text-muted text-center mb-4">Unisciti a EcoMarket per iniziare a vendere e comprare articoli
                    di seconda mano.</p>

                {{#if error}}
                <div class="alert alert-danger mb-4" role="alert">
                    {{error}}
                </div>
                {{/if}}

                <form action="/register" method="POST">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="nombre" class="form-label fw-medium">Nome</label>
                            <input type="text" class="form-control form-control-lg" id="nombre" name="nombre"
                                placeholder="Mario" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="apellidos" class="form-label fw-medium">Cognome</label>
                            <input type="text" class="form-control form-control-lg" id="apellidos" name="apellidos"
                                placeholder="Rossi" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label fw-medium">Indirizzo Email</label>
                        <input type="email" class="form-control form-control-lg" id="email" name="email"
                            placeholder="mario.rossi@esempio.com" required>
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label fw-medium">Password</label>
                        <input type="password" class="form-control form-control-lg" id="password" name="password"
                            placeholder="Crea una password sicura" required minlength="6">
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg fw-semibold">Registrati</button>
                    </div>
                </form>

                <div class="text-center mt-4">
                    <p class="text-muted mb-0">Hai già un account? <a href="/login"
                            class="text-decoration-none fw-semibold">Accedi qui</a></p>
                </div>
            </div>
        </div>
    </div>
</div>