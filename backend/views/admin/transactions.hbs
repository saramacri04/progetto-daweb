<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold"><i class="bi bi-cash-coin"></i> Manage Transactions</h2>
            <p class="text-muted">List of all transactions made on the platform.</p>
        </div>
        <a href="/admin" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Product</th>
                        <th>Buyer</th>
                        <th>Seller</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each transactions}}
                    <tr>
                        <td>#{{this.id}}</td>
                        <td><strong>{{this.product_title}}</strong></td>
                        <td>{{this.buyer_name}} {{this.buyer_surname}}</td>
                        <td>{{this.seller_name}} {{this.seller_surname}}</td>
                        <td>€{{this.agreed_price}}</td>
                        <td>
                            {{#if (eq this.status 'pending')}}
                            <span class="badge bg-warning text-dark">Pending</span>
                            {{/if}}
                            {{#if (eq this.status 'accepted')}}
                            <span class="badge bg-primary">Accepted</span>
                            {{/if}}
                            {{#if (eq this.status 'rejected')}}
                            <span class="badge bg-danger">Rejected</span>
                            {{/if}}
                            {{#if (eq this.status 'completed')}}
                            <span class="badge bg-success">Completed</span>
                            {{/if}}
                        </td>
                        <td>{{this.created_at}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            {{#unless transactions}}
            <p class="text-muted text-center my-3">No transactions found.</p>
            {{/unless}}
        </div>
        
        <!-- Pagination -->
        {{#if totalPages}}
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item {{#unless hasPrevPage}}disabled{{/unless}}">
                    <a class="page-link" href="/admin/transactions?page={{prevPage}}">Previous</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page {{currentPage}} of {{totalPages}}</span>
                </li>
                <li class="page-item {{#unless hasNextPage}}disabled{{/unless}}">
                    <a class="page-link" href="/admin/transactions?page={{nextPage}}">Next</a>
                </li>
            </ul>
        </nav>
        {{/if}}
    </div>
</div>
