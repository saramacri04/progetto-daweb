<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold"><i class="bi bi-people"></i> Manage Users</h2>
            <p class="text-muted">List of all registered users on the platform.</p>
        </div>
        <a href="/admin" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Registration Date</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each users}}
                    <tr>
                        <td>{{this.id}}</td>
                        <td>{{this.name}} {{this.surname}}</td>
                        <td>{{this.email}}</td>
                        <td>
                            {{#if (eq this.role 'admin')}}
                            <span class="badge bg-danger">Admin</span>
                            {{else}}
                            <span class="badge bg-secondary">User</span>
                            {{/if}}
                        </td>
                        <td>{{this.created_at}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            {{#unless users}}
            <p class="text-muted text-center my-3">No users found.</p>
            {{/unless}}
        </div>
        
        <!-- Pagination -->
        {{#if totalPages}}
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item {{#unless hasPrevPage}}disabled{{/unless}}">
                    <a class="page-link" href="/admin/users?page={{prevPage}}">Previous</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Page {{currentPage}} of {{totalPages}}</span>
                </li>
                <li class="page-item {{#unless hasNextPage}}disabled{{/unless}}">
                    <a class="page-link" href="/admin/users?page={{nextPage}}">Next</a>
                </li>
            </ul>
        </nav>
        {{/if}}
    </div>
</div>
